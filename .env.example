APP_NAME=py-wallet-snapshot-service
ENVIRONMENT=local
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/py_wallet
INTERNAL_API_TOKEN=change-me
SNAPSHOT_SERVICE_HOST=0.0.0.0
SNAPSHOT_SERVICE_PORT=8001
SNAPSHOT_WORKER_ENABLED=true
SNAPSHOT_SCHEDULER_ENABLED=true
SNAPSHOT_INTERVAL_SECONDS=300
SNAPSHOT_WORKER_POLL_SECONDS=5
SNAPSHOT_ENABLED_CHAINS=mainnet,base,arbitrum,bnb,linea
DEBUG_ENDPOINTS_ENABLED=true
CHAIN_TIMEOUT_SECONDS=8
ETHEREUM_TIMEOUT_SECONDS=10
# Each RPC variable accepts a comma-separated primary, backup, and emergency URL.
ETHEREUM_RPC_URL=
BASE_RPC_URL=
ARBITRUM_RPC_URL=
BNB_RPC_URL=
LINEA_RPC_URL=
RPC_COOLDOWN_SECONDS=60
RPC_STARTUP_CHECK_ENABLED=true
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
PRICE_CACHE_TTL_SECONDS=60
MAX_RETRY_ATTEMPTS=3
RETRY_BACKOFF_SECONDS=0,30,120
